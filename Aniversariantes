
SELECT

CASE 

WHEN MONTH(PPESSOA.DTNASCIMENTO) = 1 THEN 'JANEIRO'
WHEN MONTH(PPESSOA.DTNASCIMENTO) = 2 THEN 'FEVEREIRO'
WHEN MONTH(PPESSOA.DTNASCIMENTO) = 3 THEN 'MARÇO'
WHEN MONTH(PPESSOA.DTNASCIMENTO) = 4 THEN 'ABRIL'
WHEN MONTH(PPESSOA.DTNASCIMENTO) = 5 THEN 'MAIO'
WHEN MONTH(PPESSOA.DTNASCIMENTO) = 6 THEN 'JUNHO'
WHEN MONTH(PPESSOA.DTNASCIMENTO) = 7 THEN 'JULHO'
WHEN MONTH(PPESSOA.DTNASCIMENTO) = 8 THEN 'AGOSTO'
WHEN MONTH(PPESSOA.DTNASCIMENTO) = 9 THEN 'SETEMBRO'
WHEN MONTH(PPESSOA.DTNASCIMENTO) = 10 THEN 'OUTUBRO'
WHEN MONTH(PPESSOA.DTNASCIMENTO) = 11 THEN 'NOVEMBRO'
WHEN MONTH(PPESSOA.DTNASCIMENTO) = 12 THEN 'DEZEMBRO'

ELSE ''
END AS MES_NASC,

  --PFUNC.CHAPA AS CHAPA,
  PFUNC.NOME AS NOME_FUNCIONARIO,
   PFUNC.CODRECEBIMENTO AS RECEBIMENTO,


UPPER(PPESSOA.EMAIL) AS EMAIL,
FORMAT(PFUNC.DATAADMISSAO, 'dd/MM/yyyy') AS DATAADMISSAO,
PSECAO.CODIGO AS CODIGO,

  CASE
    WHEN PFUNCAO.NOME <> 'INSTRUTOR DE FORMAÇÃO PROFISSIONAL' AND
      PFUNCAO.NOME <> 'INSTRUTOR DE FORMACAO PROFISSIONAL' AND
      PFUNCAO.NOME <> 'ORIENT. DE CURSOS - INTERP. DE LIBRAS' AND
      PFUNCAO.NOME <> 'ORIENTADOR DE CURSOS' AND
      PFUNCAO.NOME <> 'PROFESSOR DE ENSINO SUPERIOR I' AND
      PFUNCAO.NOME <> 'PROFESSOR DE ENSINO SUPERIOR II' AND
      PFUNCAO.NOME <> 'PROFESSOR DE ENSINO SUPERIOR III' AND
      PFUNCAO.NOME <> 'SUPERVISOR DE ESTÁGIO' AND
      PFUNCAO.NOME <> 'SUPERVISOR DE ESTAGIO' THEN 'ADMINISTRATIVO'
    ELSE 'DOCENTE'
  END AS CLASSIFICACAO,



FORMAT(PPESSOA.DTNASCIMENTO, 'dd/MM') AS DATA_NASCIMENTO,

CASE 
        WHEN MONTH(PPESSOA.DTNASCIMENTO) = MONTH(GETDATE()) THEN 'ANIVERSARIANTE NO MES'
        ELSE 'NÃO ANIVERSARIANTE'
    END AS STATUS_ANIVERSARIO_MES,

	CASE 
        WHEN MONTH(PPESSOA.DTNASCIMENTO) = MONTH(GETDATE()) AND DAY(PPESSOA.DTNASCIMENTO) = DAY(GETDATE()) THEN 'ANIVERSARIANTE NO DIA'
        ELSE 'NÃO ANIVERSARIANTE'
    END AS STATUS_ANIVERSARIO_DIA,

	
CASE 
        WHEN MONTH(PPESSOA.DTNASCIMENTO) = MONTH(GETDATE()) THEN 'ANIVERSARIANTE NO MES'
        ELSE 'NÃO ANIVERSARIANTE'
    END AS STATUS_ANIVERSARIO_MES,

	CASE 
    WHEN MONTH(PPESSOA.DTNASCIMENTO) = MONTH(DATEADD(MONTH, 1, GETDATE())) THEN 'ANIVERSARIANTE PRÓXIMO MÊS'
    ELSE 'NÃO ANIVERSARIANTE'
END AS STATUS_ANIVERSARIO_mesproximo


FROM PFUNC(NOLOCK)
LEFT OUTER JOIN PFUNCAO(NOLOCK)
  ON ((PFUNC.CODCOLIGADA = PFUNCAO.CODCOLIGADA)
  AND (PFUNC.CODFUNCAO = PFUNCAO.CODIGO))
LEFT OUTER JOIN PFCOMPL(NOLOCK)
  ON ((PFUNC.CODCOLIGADA = PFCOMPL.CODCOLIGADA)
  AND (PFUNC.CHAPA = PFCOMPL.CHAPA))
LEFT OUTER JOIN PSECAO(NOLOCK)
  ON ((PFUNC.CODCOLIGADA = PSECAO.CODCOLIGADA)
  AND (PFUNC.CODSECAO = PSECAO.CODIGO))
LEFT OUTER JOIN AHORARIO(NOLOCK)
  ON ((PFUNC.CODCOLIGADA = AHORARIO.CODCOLIGADA)
  AND (PFUNC.CODHORARIO = AHORARIO.CODIGO))
LEFT OUTER JOIN PPESSOA(NOLOCK)
  ON ((PFUNC.CODPESSOA = PPESSOA.CODIGO))
LEFT OUTER JOIN PTPFUNC(NOLOCK)
  ON ((PFUNC.CODTIPO = PTPFUNC.CODCLIENTE))
LEFT OUTER JOIN PMOTADMISSAO(NOLOCK)
  ON ((PFUNC.CODCOLIGADA = PMOTADMISSAO.CODCOLIGADA)
  AND (PFUNC.MOTIVOADMISSAO = PMOTADMISSAO.CODCLIENTE))

LEFT OUTER JOIN TABAGP(NOLOCK)
  ON ((PFUNC.CODCOLIGADA = TABAGP.CODCOLIGADA)
  AND (PFUNC.CODSECAO = TABAGP.COD_PK))



WHERE PFUNC.CODCOLIGADA = 1
AND PFUNC.CODRECEBIMENTO <> 'O'
AND PFUNC.NOME <> 'GIRLENY DE OLIVEIRA VIANA'
AND PFUNCAO.NOME <> 'ESTAGIARIO'
AND ((PFUNC.CHAPA NOT LIKE '%T%'

AND PFUNC.CHAPA NOT LIKE '%A%'
AND PFUNC.CHAPA NOT LIKE '%D%'
AND PFUNC.CHAPA NOT LIKE '%DN%'
AND PFUNC.CHAPA NOT LIKE '%B%'
AND PFUNC.CHAPA NOT LIKE '%E%'
AND PFUNC.CHAPA NOT LIKE '22%'
AND PFUNC.DATADEMISSAO IS NULL
))
AND tabagp.UNIDADE_SEDE = 'unidade'

