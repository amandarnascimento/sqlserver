SELECT 

p.codigo as CODPESSOA,
U.CHAPA AS CHAPA,
U.NOME AS NOME_FUNCIONARIO,
C.NOME AS CARGO,

  CASE
    WHEN PFCOMPL.c011 <> 'NULL' THEN 'SIM'
    ELSE 'NÃO'
  END AS 'GRATIFICACAO',


  CASE
    WHEN C.NOME <> 'INSTRUTOR DE FORMAÇÃO PROFISSIONAL' AND
      C.NOME <> 'INSTRUTOR DE FORMACAO PROFISSIONAL' AND
      C.NOME <> 'ORIENT. DE CURSOS - INTERP. DE LIBRAS' AND
      C.NOME <> 'ORIENTADOR DE CURSOS' AND
      C.NOME <> 'PROFESSOR DE ENSINO SUPERIOR I' AND
      C.NOME <> 'PROFESSOR DE ENSINO SUPERIOR II' AND
      C.NOME <> 'PROFESSOR DE ENSINO SUPERIOR III' AND
      C.NOME <> 'SUPERVISOR DE ESTÁGIO' AND
      C.NOME <> 'SUPERVISOR DE ESTAGIO' THEN 'ADMINISTRATIVO'
    ELSE 'DOCENTE'
  END AS CLASSIFICACAO,


--S.DESCRICAO AS NOME_SEÇÃO,
S.CODIGO AS CODIGO,

CASE
    WHEN U.CODSITUACAO = 'A' THEN 'ATIVO'
    WHEN U.CODSITUACAO = 'D' THEN 'DEMITIDO'
    WHEN U.CODSITUACAO = 'E' THEN 'LICENCA MATERNIDADE'
    WHEN U.CODSITUACAO = 'F' THEN 'FERIAS'
    WHEN U.CODSITUACAO = 'I' THEN 'APOSENTADO INVALIDEZ'
    WHEN U.CODSITUACAO = 'L' THEN 'LICENCA SEM REMUNERACAO'
    WHEN U.CODSITUACAO = 'P' THEN 'AFASTADO INSS'
    WHEN U.CODSITUACAO = 'R' THEN 'LICENCA REMUNERADA'
    WHEN U.CODSITUACAO = 'T' THEN 'ACIDENTE TRABALHO'
    WHEN U.CODSITUACAO = 'V' THEN 'AVISO PREVIO'
    WHEN U.CODSITUACAO = 'Y' THEN 'LICENCA PATERNIDADE'
    WHEN U.CODSITUACAO = 'Z' THEN 'ADMISSAO PROXIMO MES'
    WHEN U.CODSITUACAO = 'C' THEN 'CONTRATO SUSPENSO'
    WHEN U.CODSITUACAO = 'G' THEN 'ESTAGIO RECESSO'
    WHEN U.CODSITUACAO = 'K' THEN 'SESSAO REQUISIÃ‡ÃƒO'
    WHEN U.CODSITUACAO = 'M' THEN 'SERVICO MILITAR'
    WHEN U.CODSITUACAO = 'N' THEN 'MANDATO SINDICAL'
    WHEN U.CODSITUACAO = 'O' THEN 'DOENCA OCUPACIONAL'
    WHEN U.CODSITUACAO = 'Q' THEN 'PRISSAO/CÁRCERE'
    WHEN U.CODSITUACAO = 'S' THEN 'MANDATO SINDICAL'
    WHEN U.CODSITUACAO = 'U' THEN 'OUTROS'
    WHEN U.CODSITUACAO = 'W' THEN 'LICENCA MATERNIDADE COMP.180'
    WHEN U.CODSITUACAO = 'X' THEN 'C/ DEMISSÃO NO MES'
    ELSE 'NULL'
  END AS 'SITUACAO',

  CASE
    WHEN U.CODRECEBIMENTO = 'M' THEN 'MENSALISTA'
    WHEN U.CODRECEBIMENTO = 'P' THEN 'HORISTA'
    WHEN U.CODRECEBIMENTO = 'H' THEN 'INTERMITENTE'
    WHEN U.CODRECEBIMENTO = 'D' THEN 'DIARISTA'
    WHEN U.CODRECEBIMENTO = 'T' THEN 'TAREFEIRO'
    WHEN U.CODRECEBIMENTO = 'O' THEN 'OUTROS'
    WHEN U.CODRECEBIMENTO = 'Q' THEN 'QUINZENALISTA'
    WHEN U.CODRECEBIMENTO = 'S' THEN 'SEMANALISTA'
    ELSE 'NULL'
  END AS 'RECEBIMENTO',



FORMAT(F.DATAINICIO,  'dd/MM/yyyy')  AS DATA_INICIO, 
FORMAT(F.DATAFIM,  'dd/MM/yyyy')  AS DATA_FIM,

CAST((F.DATAFIM -  F.DATAINICIO)AS INT)+1 AS DIAS_FERIAS,

CASE 
   WHEN MONTH(F.DATAFIM) = MONTH(F.DATAINICIO) THEN 'FÉRIAS DENTRO DO MESMO MÊS'
   ELSE 'FÉRIAS DIVIDIDA EM 2 MESES'
END AS ANALISE,


CASE WHEN MONTH(F.DATAFIM) = MONTH(F.DATAINICIO) THEN FORMAT(F.DATAINICIO,  'MM/yyyy') 
ELSE  FORMAT(F.DATAINICIO,  'MM/yyyy')   + ' e ' +  FORMAT(F.DATAFIM,  'MM/yyyy')      --CONCAT(FORMAT(F.DATAINICIO,  'MM/yyyy')+(FORMAT(F.DATAFIM,  'MM/yyyy')) 
END AS 'PERIODO'


/*CASE WHEN 
	       WHEN DATEDIFF(DAY, GETDATE(), PFUNC.INICPROGFERIAS1) >= 1 THEN DATEDIFF(DAY, GETDATE(), PFUNC.INICPROGFERIAS1)
    ELSE ' '
  END AS 'DIAS_INICIOFERIAS'*/

	
	    FROM PFUFERIASPER F (NOLOCK)
INNER JOIN PFUFERIAS E (NOLOCK) ON E.CHAPA=F.CHAPA AND E.FIMPERAQUIS=F.FIMPERAQUIS AND E.CODCOLIGADA=F.CODCOLIGADA
INNER JOIN PFUNC U (NOLOCK) ON U.CHAPA=F.CHAPA AND U.CODCOLIGADA=F.CODCOLIGADA
INNER JOIN PSECAO S (NOLOCK) ON S.CODIGO=U.CODSECAO AND S.CODCOLIGADA=U.CODCOLIGADA
INNER JOIN PFUNCAO C (NOLOCK) ON C.CODIGO=U.CODFUNCAO AND C.CODCOLIGADA=U.CODCOLIGADA
INNER JOIN PPESSOA P (NOLOCK) ON P.CODIGO=U.codpessoa
LEFT OUTER JOIN PFCOMPL(NOLOCK)
  ON ((u.CODCOLIGADA = PFCOMPL.CODCOLIGADA)
  AND (u.CHAPA = PFCOMPL.CHAPA))

INNER JOIN TABAGP T (NOLOCK) ON (S.CODIGO = T.COD_PK)


WHERE 


	  F.CHAPA NOT LIKE 'T%' 
	  AND U.CODSITUACAO NOT IN ('I', 'Z', 'D')
	  AND F.DATAINICIO > GETDATE()
	  and T.UNIDADE_SEDE = 'unidade'

/*AND F.DATAINICIO >= GETDATE() AND DATEDIFF(DAY, GETDATE(), F.DATAFIM) > 30

AND F.DATAINICIO >= (GETDATE()-CAST((F.DATAFIM -  F.DATAINICIO)AS INT)+1 )

AND F.DATAFIM < GETDATE() + (CAST((F.DATAFIM -  F.DATAINICIO)AS INT)+1)*/

--F.DATAINICIO >=:DE_DT_INICIO_GOZO AND F.DATAINICIO <=:ATÉ_DT_INICIO_GOZO
ORDER BY U.NOME


