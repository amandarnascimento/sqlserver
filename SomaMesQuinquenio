

SELECT 

PFFINANC.ANOCOMP as 'ANO',
PFFINANC.MESCOMP as 'MÊS',
CASE WHEN PFFINANC.MESCOMP = 1 THEN 'jan-23'
     WHEN PFFINANC.MESCOMP = 2 THEN 'fev-23'
	 WHEN PFFINANC.MESCOMP = 3 THEN 'mar-23'
	 WHEN PFFINANC.MESCOMP = 4 THEN 'abr-23'
	 WHEN PFFINANC.MESCOMP = 5 THEN 'mai-23'
	 WHEN PFFINANC.MESCOMP = 6 THEN 'jun-23'
	 WHEN PFFINANC.MESCOMP = 7 THEN 'jul-23'
	 WHEN PFFINANC.MESCOMP = 8 THEN 'ago-23'
	 WHEN PFFINANC.MESCOMP = 9 THEN 'set-23'
	 WHEN PFFINANC.MESCOMP = 10 THEN 'out-23'
	 WHEN PFFINANC.MESCOMP = 11 THEN 'nov-23'
	 WHEN PFFINANC.MESCOMP = 12 THEN 'dez-23'
ELSE ''
END AS 'PERÍODO',
FORMAT(SUM(VALOR), 'C', 'pt-br') AS TOTAL,
FORMAT(AVG(VALOR), 'C', 'pt-br') AS 'MÉDIA',
FORMAT(MAX(VALOR), 'C', 'pt-br') AS 'MÁXIMO',
FORMAT(MIN(VALOR), 'C', 'pt-br') AS 'MÍNIMO'

FROM PFFINANC INNER JOIN PEVENTO ON PFFINANC.CODCOLIGADA=PEVENTO.CODCOLIGADA AND PFFINANC.CODEVENTO=PEVENTO.CODIGO
INNER JOIN PFUNC ON PFFINANC.CODCOLIGADA=PFUNC.CODCOLIGADA AND PFFINANC.CHAPA=PFUNC.CHAPA

WHERE

ANOCOMP = '2023'
AND CODEVENTO IN ('0620', '0621', '0664')

GROUP BY PFFINANC.MESCOMP, PFFINANC.ANOCOMP



UNION
 

