			WHEN AABONFUN.CODABONO in (0069) THEN 'AUSENCIA - PANDEMIA BAS/TEC'
			WHEN AABONFUN.CODABONO in (0070) THEN 'AUSENCIA ABONADA -  BAS/TEC'
