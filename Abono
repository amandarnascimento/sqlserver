		WHEN AABONFUN.CODABONO = 0041 THEN 'OUTROS'
		WHEN AABONFUN.CODABONO = 0043 THEN 'OUTROS'
		WHEN AABONFUN.CODABONO = 0053 THEN 'OUTROS'
		WHEN AABONFUN.CODABONO = 0054 THEN 'OUTROS'
