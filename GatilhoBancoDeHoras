INNER JOIN PFUNC(NOLOCK)
  ON PFUNC.CHAPA = APARFUN.CHAPA
  AND PFUNC.CODCOLIGADA = APARFUN.CODCOLIGADA
INNER JOIN PSECAO(NOLOCK)
  ON PFUNC.CODSECAO = PSECAO.CODIGO
  AND PFUNC.CODCOLIGADA = PSECAO.CODCOLIGADA
INNER JOIN PFUNCAO
  ON PFUNC.CODCOLIGADA = PFUNCAO.CODCOLIGADA
  AND PFUNCAO.CODIGO = PFUNC.CODFUNCAO
INNER JOIN TABAGP(NOLOCK)
  ON TABAGP.COD_PK = PFUNC.CODSECAO
INNER JOIN PFCOMPL(NOLOCK)
  ON PFUNC.CODCOLIGADA = PFCOMPL.CODCOLIGADA
  AND PFUNC.CHAPA = PFCOMPL.CHAPA

/*WHERE ASALDOBANCOHOR.FIMPER='2023-05-15' AND PFUNC.CODSINDICATO<>'0006' AND PFUNC.CODSITUACAO NOT IN ('D','I','L','T', 'U') AND PFUNC.CHAPA NOT LIKE 'T%' 
AND PFCOMPL.C011 IS NULL*/

WHERE ASALDOBANCOHOR.FIMPER = (SELECT
  FIMMENSAL
FROM aperiodo
WHERE APERIODO.STATUSPERIODO = 2)
AND PFUNC.CODSINDICATO <> '0006'
AND PFUNC.CODSITUACAO NOT IN ('D', 'I', 'L', 'T', 'U')
AND PFUNC.CHAPA NOT LIKE 'T%'
AND PFCOMPL.C011 IS NULL
AND tabagp.UNIDADE_SEDE = 'UNIDADE'

ORDER BY PSECAO.DESCRICAO, PFUNC.NOME
